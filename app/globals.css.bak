@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap');

@tailwind base;
@tailwind components;
@tailwind utilities;

:root {
  --brand: #0071e3;
  --sidebar-width: 256px;
}

/* ── BASE ── */
* { box-sizing: border-box; }

body {
  font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'SF Pro Display', system-ui, sans-serif;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  @apply bg-surface text-default transition-colors duration-200;
}

.dashboard-shell {
  min-height: 100dvh;
  overflow: visible;
}
.dashboard-content {
  min-height: 100dvh;
  overflow: visible;
}
.dashboard-main {
  min-height: 0;
  overflow: visible;
  padding-bottom: calc(1rem + env(safe-area-inset-bottom));
}
.dashboard-topbar {
  position: sticky;
  top: 0;
  z-index: 30;
}

@media (min-width: 768px) {
  .dashboard-shell {
    position: fixed;
    inset: 0;
    height: 100vh;
    overflow: hidden;
  }
  .dashboard-content {
    height: 100vh;
    min-height: 0;
    overflow: hidden;
  }
  .dashboard-main {
    overflow-y: auto;
    padding-bottom: 1.5rem;
    -webkit-overflow-scrolling: touch;
  }
  .dashboard-topbar {
    position: static;
  }
}

/* ── LIGHT / DARK TOKENS ── */
@layer base {
  :root {
    --color-surface:        #f5f5f7;
    --color-card:           #ffffff;
    --color-border:         rgba(0,0,0,0.09);
    --color-border-soft:    rgba(0,0,0,0.05);
    --color-text:           #1d1d1f;
    --color-text-muted:     #424245;
    --color-text-faint:     #6e6e73;
    --color-sidebar:        #ffffff;
    --color-header:         rgba(255,255,255,0.85);
    --color-input-bg:       #ffffff;
    --color-table-head:     #fafafa;
    --color-hover:          #f5f5f7;
  }
  .dark {
    --color-surface:        #000000;
    --color-card:           #1c1c1e;
    --color-border:         rgba(255,255,255,0.10);
    --color-border-soft:    rgba(255,255,255,0.06);
    --color-text:           #f5f5f7;
    --color-text-muted:     #d1d1d6;
    --color-text-faint:     #8e8e93;
    --color-sidebar:        #1c1c1e;
    --color-header:         rgba(28,28,30,0.85);
    --color-input-bg:       #2c2c2e;
    --color-table-head:     #2c2c2e;
    --color-hover:          #2c2c2e;
  }
}

/* ── TAILWIND TOKEN CLASSES ── */
.bg-surface   { background-color: var(--color-surface); }
.bg-card      { background-color: var(--color-card); }
.bg-header    { background-color: var(--color-header); }
.bg-table-head { background-color: var(--color-table-head); }
.bg-hover:hover { background-color: var(--color-hover); }
.border-base  { border-color: var(--color-border); }
.border-soft  { border-color: var(--color-border-soft); }
.text-default { color: var(--color-text); }
.text-muted   { color: var(--color-text-muted); }
.text-faint   { color: var(--color-text-faint); }

/* ── SIDEBAR THEME TOKENS ── */
:root {
  --sidebar-bg:       #ffffff;
  --sidebar-border:   rgba(0,0,0,0.08);
  --sidebar-text:     #1d1d1f;
  --sidebar-muted:    #6e6e73;
  --sidebar-faint:    #aeaeb2;
  --sidebar-hover-bg: rgba(0,0,0,0.04);
  --sidebar-active-bg:#0071e3;
  --sidebar-active-text: #ffffff;
}
.dark {
  --sidebar-bg:       #1c1c1e;
  --sidebar-border:   rgba(255,255,255,0.08);
  --sidebar-text:     #f5f5f7;
  --sidebar-muted:    #8e8e93;
  --sidebar-faint:    #48484a;
  --sidebar-hover-bg: rgba(255,255,255,0.06);
}
.sidebar-panel {
  background-color: var(--sidebar-bg);
  border-right: 1px solid var(--sidebar-border);
  transition: background-color 0.2s, border-color 0.2s;
  overflow: hidden; /* never scrolls */
}
.sidebar-divider   { border-color: var(--sidebar-border); }
.sidebar-text-primary { color: var(--sidebar-text); }
.sidebar-text-muted   { color: var(--sidebar-muted); }
.sidebar-text-faint   { color: var(--sidebar-faint); }
.sidebar-badge-blue {
  font-size: 10px; font-weight: 700; padding: 2px 6px; border-radius: 999px;
  background: rgba(59,130,246,0.15); color: #3b82f6;
}
.sidebar-badge-red {
  font-size: 10px; font-weight: 700; padding: 2px 6px; border-radius: 999px;
  background: rgba(239,68,68,0.15); color: #ef4444;
}

/* ── SIDEBAR LINKS ── */
.sidebar-link {
  @apply flex items-center gap-3 px-3 py-2 rounded-lg transition-all duration-150 text-sm font-medium;
  color: var(--sidebar-muted);
  letter-spacing: -0.01em;
}
.sidebar-link:hover {
  background-color: var(--sidebar-hover-bg);
  color: var(--sidebar-text);
}
.sidebar-link.active {
  background-color: var(--sidebar-active-bg);
  color: var(--sidebar-active-text);
  box-shadow: 0 2px 8px rgba(0,113,227,0.25);
}
.dark .sidebar-link.active {
  box-shadow: 0 2px 8px rgba(0,113,227,0.40);
}

/* ── BUTTONS ── */
.btn-primary {
  background-color: #0071e3;
  color: #fff;
  font-weight: 500;
  letter-spacing: -0.01em;
  @apply active:scale-95 px-4 py-2 rounded-lg transition-all duration-150 text-sm flex items-center gap-2 disabled:opacity-50 disabled:cursor-not-allowed;
}
.btn-primary:hover { background-color: #0077ed; }
.btn-secondary {
  background-color: var(--color-border-soft);
  color: var(--color-text);
  @apply font-medium px-4 py-2 rounded-lg transition-all duration-150 text-sm flex items-center gap-2 active:scale-95;
}
.btn-secondary:hover { background-color: var(--color-border); }
.btn-danger {
  @apply bg-red-600 hover:bg-red-700 active:scale-95 text-white font-medium px-4 py-2 rounded-lg transition-all duration-150 text-sm flex items-center gap-2 disabled:opacity-50 disabled:cursor-not-allowed;
}

/* ── TOPBAR GLASS ── */
.topbar-glass {
  backdrop-filter: saturate(180%) blur(20px);
  -webkit-backdrop-filter: saturate(180%) blur(20px);
}

/* ── INPUTS ── */
.input-field {
  background-color: var(--color-input-bg);
  border: 1px solid var(--color-border);
  color: var(--color-text);
  font-family: inherit;
  letter-spacing: -0.01em;
  @apply w-full rounded-lg px-3 py-2 text-sm focus:outline-none transition-shadow duration-150;
}
.input-field:focus {
  border-color: #0071e3;
  box-shadow: 0 0 0 3px rgba(0,113,227,0.15);
}
.input-field option { background-color: var(--color-card); color: var(--color-text); }

.label {
  color: var(--color-text-muted);
  @apply block text-xs font-semibold uppercase tracking-wide mb-1;
}

/* ── TABLE ── */
.table-header {
  background-color: var(--color-table-head);
  color: var(--color-text-muted);
  @apply text-xs font-semibold uppercase tracking-wide px-4 py-3 text-left;
}
.table-cell {
  border-top-color: var(--color-border-soft);
  color: var(--color-text);
  @apply px-4 py-3 text-sm border-t whitespace-nowrap;
}

/* ── TABLE SCROLL WRAPPER ── */
.table-scroll-wrap {
  position: relative;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
  /* No box-shadow here — it causes repaint glitches during scroll */
}
/* The fade overlay lives on the PARENT .table-scroll-outer div, not on the scroll container */
.table-scroll-outer {
  position: relative;
  overflow: hidden;
  border-radius: 0 0 1rem 1rem;
}
.table-scroll-outer::after {
  content: "";
  pointer-events: none;
  position: absolute;
  top: 0; right: 0; bottom: 0;
  width: 40px;
  background: linear-gradient(to right, transparent, var(--color-card));
  opacity: 1;
  transition: opacity 0.25s ease;
  z-index: 2;
}
.table-scroll-outer.at-end::after {
  opacity: 0;
}

/* Horizontal scrollbar — always show on touch devices for discoverability */
.table-scroll-wrap::-webkit-scrollbar {
  height: 4px;
}
.table-scroll-wrap::-webkit-scrollbar-track {
  background: var(--color-surface);
  border-radius: 2px;
}
.table-scroll-wrap::-webkit-scrollbar-thumb {
  background: var(--color-border);
  border-radius: 2px;
}
.table-scroll-wrap::-webkit-scrollbar-thumb:hover {
  background: var(--color-text-faint);
}

/* ── SCROLL HINT PILL (mobile only) ── */
.scroll-hint-pill {
  display: none;
}
@media (max-width: 1023px) {
  .scroll-hint-pill {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    position: absolute;
    top: 8px;
    right: 10px;
    z-index: 10;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.03em;
    color: var(--color-text-muted);
    background: var(--color-card);
    border: 1px solid var(--color-border);
    padding: 3px 8px 3px 6px;
    border-radius: 20px;
    box-shadow: 0 1px 4px rgba(0,0,0,0.08);
    pointer-events: none;
    user-select: none;
    animation: hint-fade-in 0.3s ease-out;
  }
  .scroll-hint-pill svg {
    animation: hint-arrow 1.6s ease-in-out infinite;
  }
  @keyframes hint-arrow {
    0%, 100% { transform: translateX(0); opacity: 0.6; }
    50%       { transform: translateX(3px); opacity: 1; }
  }
}
/* ── THEME TOGGLE SPIN ── */
.theme-icon-spin {
  display: inline-flex;
  transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1), opacity 0.15s;
}
.theme-icon-spin.is-dark {
  transform: rotate(360deg);
}

/* ── CARD EXPAND ANIMATION ── */

/* ── CARDS ── */
.stat-card {
  background-color: var(--color-card);
  border: 1px solid var(--color-border);
  @apply rounded-2xl p-5 shadow-sm hover:shadow-md transition-all duration-200;
}

/* ── MODAL ANIMATION ── */
.modal-overlay {
  @apply fixed inset-0 bg-black/60 backdrop-blur-sm z-50 flex items-center justify-center p-4;
  animation: overlay-in 0.2s ease-out;
}
.modal-box {
  background-color: var(--color-card);
  border-color: var(--color-border);
  @apply rounded-2xl shadow-2xl w-full max-w-lg max-h-[90vh] overflow-y-auto border;
  animation: modal-in 0.22s cubic-bezier(0.34, 1.4, 0.64, 1);
}
.modal-box-lg {
  @apply max-w-2xl;
}
.modal-box-sm {
  @apply max-w-sm;
}

@keyframes overlay-in {
  from { opacity: 0; }
  to   { opacity: 1; }
}
@keyframes modal-in {
  from { opacity: 0; transform: scale(0.92) translateY(12px); }
  to   { opacity: 1; transform: scale(1)    translateY(0); }
}

/* ── SIDEBAR DRAWER ANIMATION ── */
.sidebar-drawer {
  animation: drawer-in 0.25s cubic-bezier(0.32, 0.72, 0, 1);
}
.sidebar-backdrop {
  animation: overlay-in 0.2s ease-out;
}
@keyframes drawer-in {
  from { transform: translateX(-100%); }
  to   { transform: translateX(0); }
}

/* ── STATUS BADGE TRANSITIONS ── */
.status-badge {
  @apply inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-semibold;
  transition: background-color 0.25s, color 0.25s, box-shadow 0.25s;
}

/* ── ROW HOVER ── */
tbody tr {
  transition: background-color 0.15s;
}

/* ── FADE-IN FOR PAGE CONTENT ── */
.page-fade-in {
  animation: fade-up 0.3s ease-out;
}
@keyframes fade-up {
  from { opacity: 0; transform: translateY(8px); }
  to   { opacity: 1; transform: translateY(0); }
}

/* ── STAT CARD ENTRANCE ── */
.stat-card {
  animation: fade-up 0.35s ease-out both;
}
.stat-card:nth-child(1) { animation-delay: 0.05s; }
.stat-card:nth-child(2) { animation-delay: 0.10s; }
.stat-card:nth-child(3) { animation-delay: 0.15s; }
.stat-card:nth-child(4) { animation-delay: 0.20s; }

/* ── BADGE PULSE (for Pending status) ── */
.badge-pulse {
  position: relative;
}
.badge-pulse::before {
  content: "";
  position: absolute;
  inset: 0;
  border-radius: inherit;
  animation: badge-pulse-ring 2s ease-out infinite;
}
@keyframes badge-pulse-ring {
  0%   { box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.35); }
  70%  { box-shadow: 0 0 0 6px rgba(239, 68, 68, 0); }
  100% { box-shadow: 0 0 0 0 rgba(239, 68, 68, 0); }
}

/* ── TOOLTIP ── */
.tooltip-enter {
  animation: tooltip-in 0.15s ease-out;
}
@keyframes tooltip-in {
  from { opacity: 0; transform: scale(0.94) translateY(4px); }
  to   { opacity: 1; transform: scale(1) translateY(0); }
}

/* ── BADGES ── */
.badge-pwp        { @apply bg-emerald-100 text-emerald-700 dark:bg-emerald-900/40 dark:text-emerald-400 text-xs font-semibold px-2 py-0.5 rounded-full; }
.badge-producer   { @apply bg-blue-100 text-blue-700 dark:bg-blue-900/40 dark:text-blue-400 text-xs font-semibold px-2 py-0.5 rounded-full; }
.badge-importer   { @apply bg-violet-100 text-violet-700 dark:bg-violet-900/40 dark:text-violet-400 text-xs font-semibold px-2 py-0.5 rounded-full; }
.badge-brandowner { @apply bg-orange-100 text-orange-700 dark:bg-orange-900/40 dark:text-orange-400 text-xs font-semibold px-2 py-0.5 rounded-full; }
.badge-simp       { @apply bg-pink-100 text-pink-700 dark:bg-pink-900/40 dark:text-pink-400 text-xs font-semibold px-2 py-0.5 rounded-full; }
.badge-paid       { @apply bg-emerald-100 text-emerald-700 dark:bg-emerald-900/40 dark:text-emerald-400 text-xs font-semibold px-2 py-0.5 rounded-full; }
.badge-partial    { @apply bg-amber-100 text-amber-700 dark:bg-amber-900/40 dark:text-amber-400 text-xs font-semibold px-2 py-0.5 rounded-full; }
.badge-unpaid     { @apply bg-red-100 text-red-700 dark:bg-red-900/40 dark:text-red-400 text-xs font-semibold px-2 py-0.5 rounded-full; }


/* ── MOBILE CARD EXPAND ANIMATION ── */
.card-expand {
  overflow: hidden;
  animation: card-expand-in 0.22s cubic-bezier(0.4, 0, 0.2, 1);
  transform-origin: top;
}
@keyframes card-expand-in {
  from {
    opacity: 0;
    max-height: 0;
    transform: scaleY(0.97);
  }
  to {
    opacity: 1;
    max-height: 800px;
    transform: scaleY(1);
  }
}

/* ── SCROLLBAR ── */
::-webkit-scrollbar { width: 5px; height: 5px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: var(--color-border); border-radius: 3px; }

/* ── DARK MODE TOGGLE SPIN ── */
.theme-icon-spin {
  animation: theme-icon-spin 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) both;
}
@keyframes theme-icon-spin {
  from { transform: rotate(-90deg) scale(0.6); opacity: 0; }
  to   { transform: rotate(0deg)   scale(1);   opacity: 1; }
}

/* ═══════════════════════════════════════════════════════════════
   LIQUID GLASS — Apple visionOS / iOS 26 inspired
   Used on: FYTabBar, FilterRail, action button groups, sidebar active
   ═══════════════════════════════════════════════════════════════ */

/* ── CSS variables for glass system ── */
:root {
  --glass-bg:          rgba(255, 255, 255, 0.55);
  --glass-bg-hover:    rgba(255, 255, 255, 0.72);
  --glass-border:      rgba(255, 255, 255, 0.75);
  --glass-border-soft: rgba(255, 255, 255, 0.40);
  --glass-shadow:      0 2px 16px rgba(0,0,0,0.08), 0 1px 4px rgba(0,0,0,0.06);
  --glass-shadow-lg:   0 8px 32px rgba(0,0,0,0.10), 0 2px 8px rgba(0,0,0,0.06);
  --glass-pill-active-bg:    rgba(0, 113, 227, 0.90);
  --glass-pill-active-border:rgba(0, 113, 227, 0.60);
  --glass-pill-active-glow:  0 0 0 1px rgba(0,113,227,0.30), 0 4px 16px rgba(0,113,227,0.28);
  --glass-pill-inactive-bg:  rgba(255,255,255,0.38);
  --glass-pill-inactive-border: rgba(255,255,255,0.60);
  --glass-pill-inactive-text: rgba(0,0,0,0.55);
  --glass-pill-inactive-hover-bg: rgba(255,255,255,0.60);
  --glass-tray-bg:     rgba(255,255,255,0.30);
  --glass-tray-border: rgba(255,255,255,0.55);
}
.dark {
  --glass-bg:          rgba(40, 40, 45, 0.55);
  --glass-bg-hover:    rgba(55, 55, 60, 0.72);
  --glass-border:      rgba(255, 255, 255, 0.14);
  --glass-border-soft: rgba(255, 255, 255, 0.08);
  --glass-shadow:      0 2px 16px rgba(0,0,0,0.30), 0 1px 4px rgba(0,0,0,0.20);
  --glass-shadow-lg:   0 8px 32px rgba(0,0,0,0.40), 0 2px 8px rgba(0,0,0,0.24);
  --glass-pill-active-bg:    rgba(0, 113, 227, 0.88);
  --glass-pill-active-border:rgba(100, 170, 255, 0.45);
  --glass-pill-active-glow:  0 0 0 1px rgba(0,113,227,0.40), 0 4px 20px rgba(0,113,227,0.35);
  --glass-pill-inactive-bg:  rgba(255,255,255,0.07);
  --glass-pill-inactive-border: rgba(255,255,255,0.12);
  --glass-pill-inactive-text: rgba(255,255,255,0.50);
  --glass-pill-inactive-hover-bg: rgba(255,255,255,0.13);
  --glass-tray-bg:     rgba(28, 28, 32, 0.55);
  --glass-tray-border: rgba(255,255,255,0.10);
}

/* ── Tray: the outer container that holds a pill group ── */
.glass-tray {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  padding: 4px;
  border-radius: 14px;
  background: var(--glass-tray-bg);
  border: 1px solid var(--glass-tray-border);
  backdrop-filter: blur(24px) saturate(180%);
  -webkit-backdrop-filter: blur(24px) saturate(180%);
  box-shadow: var(--glass-shadow);
  position: relative;
  overflow: hidden;
}

/* Subtle specular shimmer on top edge of the tray */
.glass-tray::before {
  content: '';
  position: absolute;
  top: 0; left: 8px; right: 8px;
  height: 1px;
  background: linear-gradient(90deg,
    transparent 0%,
    rgba(255,255,255,0.70) 30%,
    rgba(255,255,255,0.90) 50%,
    rgba(255,255,255,0.70) 70%,
    transparent 100%
  );
  pointer-events: none;
  border-radius: 999px;
}
.dark .glass-tray::before {
  background: linear-gradient(90deg,
    transparent 0%,
    rgba(255,255,255,0.12) 30%,
    rgba(255,255,255,0.20) 50%,
    rgba(255,255,255,0.12) 70%,
    transparent 100%
  );
}

/* Inner gloss refraction overlay */
.glass-tray::after {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: inherit;
  background: radial-gradient(
    ellipse 100% 60% at 50% -10%,
    rgba(255,255,255,0.22) 0%,
    transparent 70%
  );
  pointer-events: none;
}
.dark .glass-tray::after {
  background: radial-gradient(
    ellipse 100% 60% at 50% -10%,
    rgba(255,255,255,0.06) 0%,
    transparent 70%
  );
}

/* ── Pill button inside a glass tray ── */
.glass-pill {
  position: relative;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 5px;
  padding: 6px 13px;
  border-radius: 10px;
  font-size: 12px;
  font-weight: 600;
  letter-spacing: -0.01em;
  white-space: nowrap;
  cursor: pointer;
  border: 1px solid transparent;
  transition:
    background 0.18s ease,
    border-color 0.18s ease,
    box-shadow 0.18s ease,
    transform 0.12s cubic-bezier(0.34, 1.56, 0.64, 1),
    color 0.15s ease;
  user-select: none;
  -webkit-tap-highlight-color: transparent;
  outline: none;
  flex-shrink: 0;

  /* Inactive state */
  background: var(--glass-pill-inactive-bg);
  border-color: var(--glass-pill-inactive-border);
  color: var(--glass-pill-inactive-text);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
}

/* Specular highlight on pill top edge */
.glass-pill::before {
  content: '';
  position: absolute;
  top: 0; left: 10%; right: 10%;
  height: 1px;
  background: linear-gradient(90deg,
    transparent,
    rgba(255,255,255,0.80) 40%,
    rgba(255,255,255,0.95) 50%,
    rgba(255,255,255,0.80) 60%,
    transparent
  );
  border-radius: 999px;
  pointer-events: none;
  opacity: 0.7;
  transition: opacity 0.15s;
}
.dark .glass-pill::before {
  background: linear-gradient(90deg,
    transparent,
    rgba(255,255,255,0.15) 40%,
    rgba(255,255,255,0.25) 50%,
    rgba(255,255,255,0.15) 60%,
    transparent
  );
}

/* Hover: inactive pill gets brighter glass */
.glass-pill:hover:not(.glass-pill-active) {
  background: var(--glass-pill-inactive-hover-bg);
  border-color: rgba(255,255,255,0.75);
  color: var(--color-text);
  transform: translateY(-0.5px);
}
.dark .glass-pill:hover:not(.glass-pill-active) {
  border-color: rgba(255,255,255,0.18);
  color: rgba(255,255,255,0.80);
}

/* Active pill: solid brand with glass sheen */
.glass-pill-active {
  background: var(--glass-pill-active-bg);
  border-color: var(--glass-pill-active-border);
  color: #ffffff;
  box-shadow: var(--glass-pill-active-glow);
}

/* Active pill inner gloss */
.glass-pill-active::after {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 50%;
  border-radius: 9px 9px 0 0;
  background: linear-gradient(
    to bottom,
    rgba(255,255,255,0.20) 0%,
    transparent 100%
  );
  pointer-events: none;
}

/* Press feedback */
.glass-pill:active {
  transform: scale(0.95) translateY(0) !important;
  transition-duration: 0.06s !important;
}

/* ── Full-width glass tray (for FYTabBar strip) ── */
.glass-tray-full {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 5px 6px 5px 12px;
  border-radius: 16px;
  background: var(--glass-tray-bg);
  border: 1px solid var(--glass-tray-border);
  backdrop-filter: blur(24px) saturate(180%);
  -webkit-backdrop-filter: blur(24px) saturate(180%);
  box-shadow: var(--glass-shadow);
  position: relative;
  overflow: hidden;
}
.glass-tray-full::before {
  content: '';
  position: absolute;
  top: 0; left: 8px; right: 8px;
  height: 1px;
  background: linear-gradient(90deg,
    transparent 0%,
    rgba(255,255,255,0.70) 30%,
    rgba(255,255,255,0.90) 50%,
    rgba(255,255,255,0.70) 70%,
    transparent 100%
  );
  pointer-events: none;
}
.dark .glass-tray-full::before {
  background: linear-gradient(90deg,
    transparent 0%,
    rgba(255,255,255,0.12) 30%,
    rgba(255,255,255,0.20) 50%,
    rgba(255,255,255,0.12) 70%,
    transparent 100%
  );
}
.glass-tray-full::after {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: inherit;
  background: radial-gradient(
    ellipse 100% 60% at 50% -10%,
    rgba(255,255,255,0.18) 0%,
    transparent 70%
  );
  pointer-events: none;
}
.dark .glass-tray-full::after {
  background: radial-gradient(
    ellipse 100% 60% at 50% -10%,
    rgba(255,255,255,0.05) 0%,
    transparent 70%
  );
}

/* ── Glass action button (standalone, not in a tray) ── */
.glass-btn {
  position: relative;
  display: inline-flex;
  align-items: center;
  gap: 5px;
  padding: 7px 14px;
  border-radius: 10px;
  font-size: 12px;
  font-weight: 600;
  letter-spacing: -0.01em;
  cursor: pointer;
  border: 1px solid var(--glass-border-soft);
  background: var(--glass-bg);
  color: var(--color-text);
  backdrop-filter: blur(20px) saturate(160%);
  -webkit-backdrop-filter: blur(20px) saturate(160%);
  box-shadow: var(--glass-shadow);
  transition:
    background 0.18s ease,
    box-shadow 0.18s ease,
    transform 0.12s cubic-bezier(0.34, 1.56, 0.64, 1);
  outline: none;
  user-select: none;
  -webkit-tap-highlight-color: transparent;
  flex-shrink: 0;
  overflow: hidden;
}

.glass-btn::before {
  content: '';
  position: absolute;
  top: 0; left: 8%; right: 8%;
  height: 1px;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.90) 50%, transparent);
  pointer-events: none;
}
.dark .glass-btn::before {
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.18) 50%, transparent);
}
.glass-btn::after {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse 90% 55% at 50% -5%, rgba(255,255,255,0.18) 0%, transparent 70%);
  pointer-events: none;
}
.dark .glass-btn::after {
  background: radial-gradient(ellipse 90% 55% at 50% -5%, rgba(255,255,255,0.05) 0%, transparent 70%);
}

.glass-btn:hover {
  background: var(--glass-bg-hover);
  box-shadow: var(--glass-shadow-lg);
  transform: translateY(-1px);
}
.glass-btn:active {
  transform: scale(0.96) !important;
  transition-duration: 0.06s !important;
}

/* Primary variant */
.glass-btn-primary {
  background: rgba(0, 113, 227, 0.88);
  border-color: rgba(0, 113, 227, 0.55);
  color: #ffffff;
  box-shadow: 0 0 0 1px rgba(0,113,227,0.25), 0 4px 16px rgba(0,113,227,0.28);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
}
.glass-btn-primary::before {
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.30) 50%, transparent);
}
.glass-btn-primary::after {
  background: radial-gradient(ellipse 90% 55% at 50% -5%, rgba(255,255,255,0.22) 0%, transparent 70%);
}
.glass-btn-primary:hover {
  background: rgba(0, 119, 237, 0.95);
  box-shadow: 0 0 0 1px rgba(0,113,227,0.40), 0 6px 24px rgba(0,113,227,0.38);
}

/* ── Sidebar glass active pill ── */
.sidebar-link.active {
  background: var(--glass-pill-active-bg) !important;
  border: 1px solid var(--glass-pill-active-border) !important;
  color: #ffffff !important;
  box-shadow: var(--glass-pill-active-glow) !important;
  backdrop-filter: blur(16px) saturate(160%);
  -webkit-backdrop-filter: blur(16px) saturate(160%);
  position: relative;
  overflow: hidden;
}
.sidebar-link.active::before {
  content: '';
  position: absolute;
  top: 0; left: 8%; right: 8%;
  height: 1px;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.55) 50%, transparent);
  pointer-events: none;
}
.sidebar-link.active::after {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse 90% 50% at 50% -5%, rgba(255,255,255,0.18) 0%, transparent 70%);
  pointer-events: none;
}

/* ── Scrollable glass tray strip: for FYTabBar ── */
.glass-tray-scroll-track {
  overflow-x: auto;
  scrollbar-width: none;
  -ms-overflow-style: none;
  -webkit-overflow-scrolling: touch;
  cursor: grab;
}
.glass-tray-scroll-track::-webkit-scrollbar { display: none; }
.glass-tray-scroll-track:active { cursor: grabbing; }
